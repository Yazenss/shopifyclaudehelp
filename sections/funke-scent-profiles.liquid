              <ellipse cx="16" cy="10.5" rx="1.8" ry="3.5" stroke-width="1.25"/>
              <ellipse cx="16" cy="10.5" rx="1.8" ry="3.5" stroke-width="1.25" transform="rotate(45 16 16)"/>
