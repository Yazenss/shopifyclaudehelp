<style>
  .funke-wl {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F5F0E8;
    padding: 6rem 4rem;
    position: relative;
    overflow: hidden;
  }

  /* Subtle radial texture */
  .funke-wl::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(201, 168, 76, 0.06) 0%, transparent 65%);
    pointer-events: none;
  }

  /* Corner gold lines — top-left */
  .funke-wl::after {
    content: '';
    position: absolute;
    top: 4rem; left: 4rem;
    width: 8rem; height: 8rem;
    border-top: 1px solid rgba(201, 168, 76, 0.5);
    border-left: 1px solid rgba(201, 168, 76, 0.5);
    pointer-events: none;
  }

  .funke-wl__corner-br {
    position: absolute;
    bottom: 4rem; right: 4rem;
    width: 8rem; height: 8rem;
    border-bottom: 1px solid rgba(201, 168, 76, 0.5);
    border-right: 1px solid rgba(201, 168, 76, 0.5);
    pointer-events: none;
  }

  .funke-wl__inner {
    max-width: 68rem;
    width: 100%;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  /* Logo bar */
  .funke-wl__logobar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 7rem;
  }

  .funke-wl__logobar-line {
    flex: 1;
    max-width: 10rem;
    height: 1px;
    background: rgba(201, 168, 76, 0.45);
  }

  .funke-wl__logobar-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.2rem;
    letter-spacing: 0.55em;
    color: #C9A84C;
  }

  .funke-wl__label {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #C9A84C;
    margin-bottom: 2rem;
    display: block;
  }

  .funke-wl__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(5.5rem, 11vw, 11rem);
    line-height: 0.9;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #1C1C1E !important;
    margin: 0 0 2.5rem;
  }

  .funke-wl__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1.7;
    color: rgba(28, 28, 30, 0.6);
    margin: 0 0 2rem;
  }

  .funke-wl__divider {
    display: block;
    width: 6rem;
    height: 1px;
    background: rgba(201, 168, 76, 0.5);
    margin: 0 auto 2.5rem;
  }

  .funke-wl__body {
    font-family: 'Inter', sans-serif;
    font-size: 1.4rem;
    line-height: 1.7;
    color: rgba(28, 28, 30, 0.55);
    margin: 0 0 4.5rem;
  }

  .funke-wl__body strong {
    color: #C9A84C;
    font-weight: 600;
  }

  .funke-wl__form {
    display: flex;
    max-width: 52rem;
    margin: 0 auto 1.5rem;
  }

  .funke-wl__input {
    flex: 1;
    background: #EDE8DC;
    border: 1px solid #1C1C1E;
    border-right: none;
    color: #1C1C1E;
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    padding: 1.9rem 2.2rem;
    outline: none;
    transition: border-color 0.2s;
    border-radius: 0;
    -webkit-appearance: none;
    appearance: none;
  }

  .funke-wl__input::placeholder {
    color: rgba(28, 28, 30, 0.35);
    letter-spacing: 0.04em;
  }

  .funke-wl__input:focus {
    border-color: #C9A84C;
  }

  .funke-wl__btn {
    background: #1C1C1E;
    color: #F5F0E8;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.7rem;
    letter-spacing: 0.1em;
    padding: 1.9rem 3.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
    border-radius: 0;
    -webkit-appearance: none;
    appearance: none;
  }

  .funke-wl__btn:hover {
    background: #3A3A3A;
  }

  .funke-wl__note {
    font-family: 'Inter', sans-serif;
    font-size: 1.15rem;
    color: rgba(28, 28, 30, 0.38);
    letter-spacing: 0.06em;
  }

  .funke-wl__success {
    text-align: center;
    padding: 3rem 2rem;
  }

  .funke-wl__success-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 8vw, 5.5rem);
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #C9A84C;
    margin: 0 0 1.6rem;
    line-height: 1;
  }

  .funke-wl__success-divider {
    display: block;
    width: 5rem;
    height: 1px;
    background: rgba(201, 168, 76, 0.5);
    margin: 0 auto 1.8rem;
  }

  .funke-wl__success-msg {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.7;
    color: rgba(28, 28, 30, 0.6);
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .funke-wl {
      padding: 5rem 2.4rem;
    }
    .funke-wl__form {
      flex-direction: column;
      gap: 1.2rem;
    }
    .funke-wl__input {
      border-right: 1px solid #1C1C1E;
    }
    .funke-wl__btn {
      width: 100%;
      padding: 1.9rem;
    }
    .funke-wl__corner-br {
      display: none;
    }
  }
</style>

<section class="funke-wl">
  <div class="funke-wl__corner-br" aria-hidden="true"></div>

  <div class="funke-wl__inner">

    <div class="funke-wl__logobar">
      <div class="funke-wl__logobar-line"></div>
      <span class="funke-wl__logobar-text">FUNKE</span>
      <div class="funke-wl__logobar-line"></div>
    </div>

    <span class="funke-wl__label">Early Access</span>
    <h1 class="funke-wl__title">FUNKE IS COMING.</h1>
    <p class="funke-wl__subtitle">Premium car fragrances engineered for European car enthusiasts.</p>
    <span class="funke-wl__divider"></span>
    <p class="funke-wl__body">Join the waitlist for exclusive early access and <strong>15% off your first order</strong>.</p>

    {%- form 'customer', id: 'FunkeWaitlistForm' -%}
      <input type="hidden" name="contact[tags]" value="waitlist">
      {%- if form.posted_successfully? -%}
        <div class="funke-wl__success">
          <p class="funke-wl__success-title">YOU'RE ON THE LIST.</p>
          <span class="funke-wl__success-divider"></span>
          <p class="funke-wl__success-msg">We'll be in touch before launch.<br>Check your inbox for a confirmation email.</p>
        </div>
      {%- else -%}
        <div class="funke-wl__form">
          <input
            type="email"
            name="contact[email]"
            class="funke-wl__input"
            id="WaitlistEmail"
            placeholder="Enter your email"
            value="{{ form.email }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            aria-label="Email address"
            required
          >
          <button type="submit" class="funke-wl__btn" name="commit">JOIN THE WAITLIST</button>
        </div>
        <p class="funke-wl__note">No spam. Exclusive access only.</p>
      {%- endif -%}
    {%- endform -%}

  </div>
</section>

{% schema %}
{
  "name": "FUNKE Waitlist",
  "tag": "section",
  "limit": 1,
  "settings": [],
  "presets": [
    {
      "name": "FUNKE Waitlist"
    }
  ]
}
{% endschema %}
