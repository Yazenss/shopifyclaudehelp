<style>
  .funke-showcase {
    padding: 9rem 0;
    background: #1E1E24;
    position: relative;
  }

  .funke-showcase::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201, 168, 76, 0.35), transparent);
  }

  .funke-showcase__inner {
    max-width: 130rem;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .funke-showcase__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 5rem;
    gap: 2rem;
  }

  .funke-showcase__header-left {
    flex: 1;
  }

  .funke-showcase__label {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #C9A84C;
    margin-bottom: 0.8rem;
    display: block;
  }

  .funke-showcase__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 6vw, 7rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #F5F0E8;
    margin: 0;
    line-height: 1;
  }

  .funke-showcase__view-all {
    flex-shrink: 0;
  }

  .funke-showcase__view-all-link {
    font-family: 'Inter', sans-serif;
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.45);
    text-decoration: none;
    border-bottom: 1px solid rgba(245, 240, 232, 0.15);
    padding-bottom: 0.3rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .funke-showcase__view-all-link:hover {
    color: #C9A84C;
    border-color: rgba(201, 168, 76, 0.4);
  }

  .funke-showcase__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.4rem;
  }

  /* ---- Product Card ---- */
  .funke-pcard {
    background: #0D0D0D;
    border: 1px solid rgba(201, 168, 76, 0.18);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.35s ease;
    display: flex;
    flex-direction: column;
  }

  .funke-pcard:hover {
    border-color: rgba(201, 168, 76, 0.5);
    transform: translateY(-5px);
  }

  .funke-pcard__image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #111118;
    display: block;
    text-decoration: none;
  }

  .funke-pcard__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    display: block;
  }

  .funke-pcard:hover .funke-pcard__image {
    transform: scale(1.04);
  }

  .funke-pcard__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #111118 0%, #1E1E24 100%);
  }

  .funke-pcard__placeholder svg {
    opacity: 0.2;
  }

  .funke-pcard__badge {
    position: absolute;
    top: 1.4rem;
    left: 1.4rem;
    background: #C9A84C;
    color: #0D0D0D;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    z-index: 1;
  }

  .funke-pcard__body {
    padding: 2.6rem 2.6rem 3rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .funke-pcard__category {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #C9A84C;
    margin-bottom: 0.8rem;
  }

  .funke-pcard__name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #F5F0E8;
    margin: 0 0 1.2rem;
    line-height: 1;
    text-decoration: none;
    display: block;
  }

  .funke-pcard__name:hover {
    color: #C9A84C;
  }

  .funke-pcard__desc {
    font-family: 'Inter', sans-serif;
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(245, 240, 232, 0.45);
    margin: 0 0 2.4rem;
    flex: 1;
  }

  .funke-pcard__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    margin-top: auto;
  }

  .funke-pcard__price {
    font-family: 'Inter', sans-serif;
    font-size: 2.2rem;
    font-weight: 500;
    color: #C9A84C;
    line-height: 1;
  }

  .funke-pcard__btn {
    background: #C9A84C;
    color: #0D0D0D;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.12em;
    padding: 1.1rem 2.4rem;
    text-decoration: none;
    transition: background 0.2s ease;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }

  .funke-pcard__btn:hover {
    background: #b8923f;
    color: #0D0D0D;
  }

  .funke-pcard__gold-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #C9A84C;
    transition: width 0.4s ease;
  }

  .funke-pcard:hover .funke-pcard__gold-line {
    width: 100%;
  }

  @media screen and (max-width: 989px) {
    .funke-showcase__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .funke-showcase {
      padding: 6rem 0;
    }
    .funke-showcase__inner {
      padding: 0 2rem;
    }
    .funke-showcase__header {
      flex-direction: column;
      align-items: flex-start;
    }
    .funke-showcase__grid {
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }
  }
</style>

<section class="funke-showcase">
  <div class="funke-showcase__inner">

    <div class="funke-showcase__header">
      <div class="funke-showcase__header-left">
        <span class="funke-showcase__label">The Collection</span>
        <h2 class="funke-showcase__title">{{ section.settings.title | default: 'THE COLLECTION' }}</h2>
      </div>
      <div class="funke-showcase__view-all">
        <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="funke-showcase__view-all-link">
          View All &rarr;
        </a>
      </div>
    </div>

    <div class="funke-showcase__grid">
      {%- assign sc = collections[section.settings.collection] -%}
      {%- if sc != blank and sc.products.size > 0 -%}
        {%- for product in sc.products limit: 3 -%}
          <article class="funke-pcard">
            <a href="{{ product.url }}" class="funke-pcard__image-wrap" aria-label="{{ product.title | escape }}">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 900 }}"
                  alt="{{ product.featured_image.alt | escape | default: product.title }}"
                  class="funke-pcard__image"
                  loading="lazy"
                  width="900"
                  height="675"
                >
              {%- else -%}
                <div class="funke-pcard__placeholder">
                  {{ 'product-' | append: forloop.index | placeholder_svg_tag }}
                </div>
              {%- endif -%}
              {%- if product.compare_at_price > product.price -%}
                <span class="funke-pcard__badge">Sale</span>
              {%- endif -%}
            </a>
            <div class="funke-pcard__body">
              <span class="funke-pcard__category">{{ product.type | default: 'Car Fragrance' }}</span>
              <a href="{{ product.url }}" class="funke-pcard__name">{{ product.title }}</a>
              <p class="funke-pcard__desc">{{ product.description | strip_html | truncate: 85 }}</p>
              <div class="funke-pcard__footer">
                <span class="funke-pcard__price">{{ product.price | money }}</span>
                <a href="{{ product.url }}" class="funke-pcard__btn">VIEW PRODUCT</a>
              </div>
            </div>
            <div class="funke-pcard__gold-line"></div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          {%- assign ptitles = 'FUNKE Starter Kit,FUNKE Fragrance Oil Refill,FUNKE Cotton Pad Refill' | split: ',' -%}
          {%- assign pdescs = 'Complete system. Zinc alloy vent clip + fragrance oil + 3 cotton pads. Choose your scent.,Premium fragrance oil. 30–60 day lasting scent. LEDER or AUTOBAHN.,6-pack premium cotton pad inserts for your FUNKE vent clip diffuser.' | split: ',' -%}
          {%- assign pprices = '$39.99,$14.99,$9.99' | split: ',' -%}
          <article class="funke-pcard">
            <div class="funke-pcard__image-wrap">
              <div class="funke-pcard__placeholder">
                {{ 'product-' | append: i | placeholder_svg_tag }}
              </div>
            </div>
            <div class="funke-pcard__body">
              <span class="funke-pcard__category">Car Fragrance</span>
              <span class="funke-pcard__name">{{ ptitles[forloop.index0] }}</span>
              <p class="funke-pcard__desc">{{ pdescs[forloop.index0] }}</p>
              <div class="funke-pcard__footer">
                <span class="funke-pcard__price">{{ pprices[forloop.index0] }}</span>
                <a href="/collections/all" class="funke-pcard__btn">VIEW PRODUCT</a>
              </div>
            </div>
            <div class="funke-pcard__gold-line"></div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "FUNKE Product Showcase",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "THE COLLECTION"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Feature"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    }
  ],
  "presets": [
    {
      "name": "FUNKE Product Showcase",
      "settings": {
        "title": "THE COLLECTION"
      }
    }
  ]
}
{% endschema %}
